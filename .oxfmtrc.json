{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [],

  "semi": false,
  "singleQuote": true,
  "jsxSingleQuote": true,

  "sortImports": {
    "groups": [
      "type-import",
      ["value-builtin", "value-external"],
      "type-internal",
      "value-internal",
      ["type-parent", "type-sibling", "type-index"],
      ["value-parent", "value-sibling", "value-index"],
      "unknown"
    ]
  },

  "sortTailwindcss": {
    "stylesheet": "./src/styles.css",
    "functions": ["clsx", "cn"]
  }
}
